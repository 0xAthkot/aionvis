# Copy to .env.local and pick a mode.

# --- Mode A: standalone in-browser mock (no backend, no GPU needed) ---
NEXT_PUBLIC_USE_MOCKS=true

# --- Mode B: real backend (local or remote) — uncomment and adjust ---
# NEXT_PUBLIC_USE_MOCKS=false
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
