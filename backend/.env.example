# Copy to .env and fill in.

# Prompt Agent + Semantic Critic — any OpenAI-compatible chat endpoint.
# The intended deployment is Gemma via vLLM on the MI300X (one multimodal
# model serves both agents):
#   vllm serve google/gemma-3-27b-it --port 8001
# When the endpoint is unreachable the Prompt Agent falls back to a
# deterministic local template expander (labeled as such in the UI) and
# the Semantic Critic is skipped — everything still runs.
LLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL=google/gemma-3-27b-it
# Optional — vLLM ignores it; set only for endpoints that require auth.
LLM_API_KEY=
# Shown as the Prompt Agent's provider in the UI.
LLM_PROVIDER_LABEL=vLLM · MI300X (local)

# Where the frontend reaches this backend (used to mint image/model URLs).
PUBLIC_BASE_URL=http://localhost:8000

# API key for this backend. Empty = open (same-machine dev). Set it before
# exposing the node publicly: /api/v1 then requires
# "Authorization: Bearer <key>" (or X-API-Key) and /ws/v1 takes "?token=".
# The UI's Hardware page ("Connect AMD Developer Cloud") stores and sends it.
# deploy_mi300x.sh mints one automatically. /files stays public by design.
AA_API_KEY=

# Vision Agent backend: "yoloe" (open-vocab, fits 8 GB) or "sam3"
# (gated facebook/sam3 checkpoint — the MI300X path).
VISION_BACKEND=yoloe

# Synthesis. The generator (FLUX.1-schnell or SDXL) is the user's explicit
# per-run choice in the wizard, honored verbatim: nodes with
# < FLUX_MIN_VRAM_GB (or no GPU) REJECT flux runs at creation — checked
# BEFORE downloading the 24 GB FLUX checkpoint, never silently swapped.
# SDXL-Turbo for the dev card; MI300X uses
# SDXL_MODEL=stabilityai/stable-diffusion-xl-base-1.0.
SDXL_MODEL=stabilityai/sdxl-turbo
FLUX_MODEL=black-forest-labs/FLUX.1-schnell
FLUX_MIN_VRAM_GB=24

# Semantic Critic — a VLM double-checks a sample of accepted labels per run
# (each check is a tiny downscaled crop). Uses LLM_MODEL unless
# SEMANTIC_CRITIC_MODEL points the critic at a different vision model.
SEMANTIC_CRITIC=true
SEMANTIC_CRITIC_MODEL=
SEMANTIC_CRITIC_MAX_CHECKS=8

# Demo-scale caps so a full run stays in the minutes range locally.
# Keep MAX_EPOCHS ≥ 60: YOLO confidence stays near zero on tiny datasets
# below ~40 epochs, and the inference playground needs a model that detects.
MAX_IMAGES_PER_RUN=48
MAX_EPOCHS=80

# GPU sizing. Defaults fit an 8 GB card; the MI300X profile
# (deploy_mi300x.sh) raises these to 96 / 1024 / true so the 192 GB card
# is actually fed and stage models stay resident between runs.
MAX_BATCH_SIZE=8
MAX_TRAIN_IMAGE_SIZE=640
KEEP_MODELS_WARM=false

# Parallel swarm (MI300X profile: streaming / 2 / true).
# PIPELINE_MODE=streaming overlaps synthesis → vision → critic as
# producer/consumer streams on one card — requires KEEP_MODELS_WARM=true
# (falls back to sequential with a warning otherwise). GPU_SLOTS is how many
# pipeline runs share the card concurrently. AUTO_BATCH=true makes training
# size its batch to the VRAM actually free at train start instead of the
# MAX_BATCH_SIZE integer ceiling.
PIPELINE_MODE=sequential
GPU_SLOTS=1
AUTO_BATCH=false
