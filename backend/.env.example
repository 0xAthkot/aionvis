# Copy to .env and fill in.

# Prompt Agent + Semantic Critic — any OpenAI-compatible chat endpoint.
# The intended deployment is Gemma via vLLM on the MI300X (one multimodal
# model serves both agents):
#   vllm serve google/gemma-3-27b-it --port 8001
# When the endpoint is unreachable the Prompt Agent falls back to a
# deterministic local template expander (labeled as such in the UI) and
# the Semantic Critic is skipped — everything still runs.
LLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL=google/gemma-3-27b-it
# Optional — vLLM ignores it; set only for endpoints that require auth.
LLM_API_KEY=
# Shown as the Prompt Agent's provider in the UI.
LLM_PROVIDER_LABEL=vLLM · MI300X (local)

# Where the frontend reaches this backend (used to mint image/model URLs).
PUBLIC_BASE_URL=http://localhost:8000

# Vision Agent backend: "yoloe" (open-vocab, fits 8 GB) or "sam3"
# (gated facebook/sam3 checkpoint — the MI300X path).
VISION_BACKEND=yoloe

# Synthesis checkpoint. SDXL-Turbo for the dev card; on the MI300X try
# SDXL_MODEL=stabilityai/stable-diffusion-xl-base-1.0 or FLUX.1-schnell.
SDXL_MODEL=stabilityai/sdxl-turbo

# Semantic Critic — a VLM double-checks a sample of accepted labels per run
# (each check is a tiny downscaled crop). Uses LLM_MODEL unless
# SEMANTIC_CRITIC_MODEL points the critic at a different vision model.
SEMANTIC_CRITIC=true
SEMANTIC_CRITIC_MODEL=
SEMANTIC_CRITIC_MAX_CHECKS=8

# Demo-scale caps so a full run stays in the minutes range locally.
# Keep MAX_EPOCHS ≥ 60: YOLO confidence stays near zero on tiny datasets
# below ~40 epochs, and the inference playground needs a model that detects.
MAX_IMAGES_PER_RUN=48
MAX_EPOCHS=80
